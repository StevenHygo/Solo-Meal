NODE_ENV=development
API_HOST=127.0.0.1
API_PORT=8787
API_DATA_SOURCE=postgres
DATABASE_URL=postgres://solo_meal:solo_meal_dev@127.0.0.1:5432/solo_meal
CORS_ORIGINS=http://127.0.0.1:4173,http://localhost:4173
# Keep public feedback disabled until storage, privacy and operator procedures are ready.
FEEDBACK_API_ENABLED=false
# The operator API is enabled only when this token is set. Use a random value of at least 32 characters.
# ADMIN_API_TOKEN=replace-with-a-random-secret-of-at-least-32-characters
LOG_LEVEL=info

# Run the outbox worker separately from the API process. Production URLs must use HTTPS.
# OUTBOX_WEBHOOK_URL=https://events.example.com/solo-meal
# OUTBOX_WEBHOOK_TOKEN=replace-with-a-dedicated-delivery-secret
OUTBOX_BATCH_SIZE=25
OUTBOX_MAX_ATTEMPTS=5
OUTBOX_LEASE_SECONDS=60
OUTBOX_REQUEST_TIMEOUT_MS=5000
