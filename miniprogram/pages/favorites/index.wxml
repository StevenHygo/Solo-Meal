<view class="page favorites-page">
  <view class="eyebrow">PRIVATE LIST</view>
  <view class="favorites-title">我的收藏</view>
  <view class="favorites-subtitle">{{subtitle}}</view>

  <view wx:if="{{count}}" class="favorite-list">
    <view wx:for="{{favorites}}" wx:key="id" class="favorite-card card" data-id="{{item.id}}" bindtap="openDetail">
      <view class="favorite-accent"></view>
      <view class="favorite-content">
        <view class="favorite-head">
          <view>
            <view class="favorite-name">{{item.name}}</view>
            <view class="favorite-meta">{{item.cuisine}} · {{item.distance}}m · ¥{{item.priceMin}}-{{item.priceMax}}</view>
          </view>
          <view class="favorite-score">{{item.soloScore}}</view>
        </view>
        <view class="favorite-reason"><text class="reason-dot">●</text>{{item.reasons[0]}}</view>
        <view class="favorite-foot">
          <text>{{item.openNow ? '营业中' : '暂未营业'}} · {{item.hours}}</text>
          <button class="remove-button" data-id="{{item.id}}" catchtap="removeFavorite">取消收藏</button>
        </view>
      </view>
    </view>
  </view>

  <view wx:else class="favorite-empty card">
    <view class="empty-symbol">♡</view>
    <view class="empty-title">先收下几家稳妥的店</view>
    <view class="empty-copy">收藏是私有的，只保存在你的设备。点击餐厅详情页的收藏按钮即可加入。</view>
    <button class="primary-button" bindtap="goDiscover">去发现附近餐厅</button>
  </view>

  <view wx:if="{{count}}" class="privacy-tip"><text>⌾</text><text>v0 收藏仅保存在本机，不公开、不分享给其他用户。</text></view>
</view>
